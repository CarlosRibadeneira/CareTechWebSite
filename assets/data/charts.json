  "sql_cases": [
    {
      "id": "books_checked_out",
      "title": "Most checked-out titles",
      "question": "Which books are borrowed most frequently?",
      "query": "SELECT BOOK.BOOK_NUM, BOOK_TITLE, COUNT(CHECK_NUM) AS TIMES_CHECKED_OUT\\nFROM BOOK JOIN CHECKOUT ON BOOK.BOOK_NUM = CHECKOUT.BOOK_NUM\\nGROUP BY BOOK.BOOK_NUM, BOOK_TITLE\\nORDER BY COUNT(CHECK_NUM) DESC, BOOK.BOOK_NUM DESC;",
      "columns": ["Book", "Title", "Times Checked Out"],
      "rows": [
        [101, "Database Design Fundamentals", 14],
        [205, "Cloud Systems in Practice", 11],
        [312, "Programming Logic Essentials", 9],
        [118, "Data Modeling for Teams", 8]
      ]
    },
    {
      "id": "top_patrons",
      "title": "High-activity patrons",
      "question": "Which patrons show consistent borrowing activity?",
      "query": "SELECT PATRON.PAT_ID, PAT_LNAME, COUNT(CHECKOUT.PAT_ID) AS NUM_CHECKOUTS,\\nCOUNT(DISTINCT BOOK_NUM) AS NUM_DIFFERENT_BOOKS\\nFROM PATRON JOIN CHECKOUT ON PATRON.PAT_ID = CHECKOUT.PAT_ID\\nGROUP BY PATRON.PAT_ID, PAT_LNAME\\nHAVING COUNT(CHECKOUT.PAT_ID) >= 3\\nORDER BY NUM_DIFFERENT_BOOKS DESC, NUM_CHECKOUTS DESC, PATRON.PAT_ID;",
      "columns": ["Patron ID", "Last Name", "Checkouts", "Distinct Books"],
      "rows": [
        [4432, "Miles", 12, 9],
        [2271, "Carter", 9, 7],
        [3155, "Sanchez", 7, 6],
        [5298, "Hughes", 6, 5]
      ]
    },
    {
      "id": "salary_by_rank",
      "title": "Salary behavior by ranking tier",
      "question": "Do higher-ranked clubs allocate higher salaries by position?",
      "query": "SELECT top10, position, AVG(base_salary) AS avg_salary\\nFROM merged_salary_ranking_table\\nGROUP BY top10, position\\nORDER BY top10 DESC, position;",
      "columns": ["Ranking Tier", "Position", "Average Salary"],
